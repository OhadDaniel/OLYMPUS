# ── Runtime LLM ────────────────────────────────────────────────
OPENAI_API_KEY=
MAXWELL_MODEL=gpt-4o
MAXWELL_MAX_TURNS=8

# ── Database (MongoDB Atlas M0 — SRV connection string) ─────────
MONGODB_URI=

# ── Google (read-only: calendar.readonly + gmail.readonly) ──────
# OAuth redirect: http://localhost:3011/auth/google/callback  (3001 was taken by another app)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Telegram (@BotFather /newbot) ──────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── URLs & locale ──────────────────────────────────────────────
APP_URL=http://localhost:5273
API_URL=http://localhost:3011
TZ_DEFAULT=Asia/Jerusalem

# ── Harness logging: file (default) | stderr | stdout | silent ──
MAXWELL_LOG=file
MAXWELL_LOG_DIR=logs
